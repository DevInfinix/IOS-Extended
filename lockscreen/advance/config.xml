<Config>
  <Group text="Welcome to IOS Extended😋!&#x000A;Please read the instructions carefully before use:&#x000A;① After setting up theme functions, please lock and unlock your screen to apply changes.&#x000A;② We recommend restarting your phone after applying the theme.&#x000A;③ Scroll to the bottom of this page for support or to join the discussions..."/>
  
  <Group text="Join our Telegram or GitHub for updates and support">
    <StringInput text="Facebook Group" default="https://thesamstudios.pages.dev"/>
    <StringInput text="Telegram Channel" default="https://t.me/devinfinix_labs_discussions"/>
    <StringInput text="Discussion Group" default="https://t.me/devinfinix_labs_discussions"/>
  </Group>
  
  <Group text="1. Wallpapers">
    <ImagePicker text="Set Lockscreen Wallpaper (Foreground Depth)" summary="Do not use standard wallpapers here (use wallpapers with depth/portrait effects)" id="dzjsbz_s"/>
    <ImagePicker text="Set Background Wallpaper (Background)" summary="Insert standard lockscreen background here" id="dzjsbz_x"/>
  </Group>
  
  <Group text="2. Unlock Gesture Settings">
    <NumberChoice text="Swipe to Unlock Style" summary="" id="Unlock_Style" default="0">
      <Item value="0" text="Swipe anywhere (Short distance)"/>
      <Item value="1" text="Swipe anywhere (Long distance)"/>
      <Item value="2" text="Swipe up from the bottom edge"/>
    </NumberChoice>
    <NumberChoice text="Background effect on swipe up" summary="" id="unlock_blur" default="1">
      <Item value="0" text="No wallpaper transition"/>
      <Item value="1" text="Blurred wallpaper"/>
      <Item value="2" text="Gradual blur from bottom to top"/>
      <Item value="3" text="Zoom out and blur wallpaper"/>
    </NumberChoice>
    <NumberChoice text="UI transition when swiping up" summary="Includes: time widget, music, notifications and other interface elements" id="Unlock_Alpha" default="1">
      <Item value="0" text="Move up only"/>
      <Item value="1" text="Move up and fade out"/>
    </NumberChoice>
  </Group>
  
  <Group text="3. Screen Unlock Animations">
    <CheckBox summary="Show real-time weather animations" id="sstqkg" text="Real-time Weather Effect" default="1" />
    <NumberChoice text="Weather effect duration" id="sstqxsxg" default="0">
      <Item value="0" text="Show for 10 seconds"/>
      <Item value="1" text="Always show"/>
    </NumberChoice>
    <NumberChoice text="Unlock screen wake animation" summary="Lighting effects when screen turns on" id="effects_id" default="0">
      <Item value="0" text="Off"/>
      <Item value="1" text="Effect 1"/>
      <Item value="2" text="Effect 2"/>
      <Item value="3" text="Effect 3"/>
      <Item value="4" text="Effect 4"/>
      <Item value="5" text="Effect 5"/>
      <Item value="6" text="Effect 6"/>
      <Item value="7" text="Effect 7"/>
    </NumberChoice>
    <NumberChoice text="Background wallpaper transitions" summary="" id="bz_show" default="0">
      <Item value="0" text="Off"/>
      <Item value="1" text="Effect 1"/>
      <Item value="2" text="Effect 2"/>
    </NumberChoice>
  </Group>
  
  <Group text="4. Dynamic Island Settings">
    <NumberChoice text="Dynamic Island style" summary="Select your preferred Dynamic Island layout" id="island_id" default="1">
      <Item value="0" text="Style 1"/>
      <Item value="1" text="Style 2"/>
      <Item value="2" text="Style 3"/>
      <Item value="3" text="Style 4"/>
    </NumberChoice>
    <CheckBox text="Dynamic Island: Charging status" summary="" id="island_charge" default="0"/>
    <CheckBox text="Dynamic Island: Notifications" summary=" " id="island_notic" default="0"/>
    <CheckBox text="Dynamic Island: Music player" summary=" " id="island_music" default="1"/>
    <CheckBox text="Dynamic Island: Flashlight widget" summary="Display flashlight animation on dynamic island" id="island_flash_btn" default="0" />
    <CheckBox text="Show song title and lyrics on Dynamic Island" summary=" " id="island_lyric" default="1"/>
    <NumberInput text="Dynamic Island Y-axis offset" id="island_y" default="12" summary="Offset from top of screen (default 12px)"/>
    <NumberInput text="Dynamic Island X-axis offset" id="island_x" default="0" summary="Default: 0. Negative values shift left, positive values shift right (-300 to 300)"/>
    <NumberInput text="Notch Y-offset (Styles 2, 3, 4)" id="circle_y" default="24" summary="Notch offset from top of screen (default 24px)"/>
  </Group>
  
  <Group text="5. Wallpaper Advanced Settings">
    <CheckBox text="Wallpaper gravity parallax effect" summary="Enables 3D parallax on wallpaper. Auto-scales foreground wallpaper slightly" id="Gravity_vis" default="0"/>
    <CheckBox text="Invert gravity parallax motion" summary="Inverts direction of depth parallax movement" id="GravityReversal" default="0"/>
    <NumberChoice text="Depth of field shadow effect" summary="Adds a soft shadow underneath depth wallpaper layers" id="js_shadow_vis" default="1">
      <Item value="0" text="Off"/>
      <Item value="1" text="Enabled (Drop shadow)"/>
      <Item value="2" text="Enabled (Fade-in shadow)"/>
    </NumberChoice>
    <CheckBox text="Wallpaper scale animation on wake" summary="Wallpaper scales up smoothly when screen wakes" id="bz_ani" default="0"/>
    <CheckBox text="Wallpaper scale-down animation on lock" summary="Wallpaper scales down smoothly when lockscreen is dismissed" id="reduce_on" default="1"/>
    <NumberChoice text="Auto-cycle background wallpaper" summary="" id="wallpaper_auto" default="0">
      <Item value="0" text="Off"/>
      <Item value="1" text="Cycle every minute"/>
      <Item value="2" text="Cycle every hour"/>
      <Item value="3" text="Cycle every day"/>
    </NumberChoice>
    <CheckBox text="Double tap edges to switch wallpaper" id="double_pic" summary="Double-tap right side for next wallpaper, double-tap left side for previous wallpaper" default="0"/>
    <NumberChoice text="Auto-dim wallpaper" summary="" id="bg_dark" default="0">
      <Item value="0" text="Do not dim"/>
      <Item value="1" text="Dim in Dark Mode"/>
      <Item value="2" text="Dim after sunset"/>
    </NumberChoice>
    <NumberInput text="Wallpaper dark mode dimming (%)" summary="Wallpaper dark percentage (Recommended: 20-80, default is 50)" id="darkmode_wallpaper_a" default="50"/>
  </Group>
  
  <Group text="6. Time &amp; Date customization">
    <StringInput text="Custom phrase (Date style 6)" summary="" id="signature0" default="Have Nice A Day"/>
    <StringInput text="Custom phrase (Date style 7)" summary="" id="signature" default="DevInfinix"/>
    <StringInput text="-------------------------" id="2" default="" summary=""/>
    <NumberInput text="Time widget Y-axis position" id="time_move_up" default="50" summary="Adjust widget Y offset (Range: 0-150, default is 50)"/>
    <CheckBox text="Time widget wake fade animation" summary="Fades and scales time text on screen wake" id="disable_kp_Anim" default="0"/>
    <CheckBox text="Show Alarm/Earbuds battery" summary="Shows earbuds battery levels or alarm info below clock. (Earbuds have priority when connected)" id="Wisdomcapsule" default="0"/>
  </Group>
  
  <Group text="7. Lockscreen Widget customization">
    <StringInput text="Custom Lockscreen Signature" summary="" id="signature1" default="DevInfinix"/>
    <StringInput text="(Widget 9) Custom Text Line 1" summary="" id="sign01" default="IOS Extended"/>
    <StringInput text="(Widget 9) Custom Text Line 2" summary="" id="sign02" default="Stay inspired"/>
    <StringInput text="(Widget 9) Custom Text Line 3" summary="" id="sign03" default="And keep moving forward!"/>
  </Group>
  
  <Group text="8. Music Player Settings">
    <CheckBox text="Enable Music Player" summary="Shows music player card on lockscreen when active" id="music_btn" default="1"/>
    <CheckBox text="Landscape music visualizer mode" summary="Tap album art to maximize, then rotate landscape to show full-screen music visualizer" id="land_music_vis" default="0"/>
    <NumberChoice text="Music &amp; Notification placement" id="musicorder_id" default="1" summary="Note: With certain layouts, music and notification cards will automatically display at the bottom.">
      <Item value="0" text="Align to top"/>
      <Item value="1" text="Align to bottom"/>
    </NumberChoice>
    <ImagePicker text="Custom Album Cover (JPEG/PNG)" summary="Fallback cover when none is found. Crop square before selecting. Keep size under 800x800px." id="album_diy"/>
    <NumberChoice text="Music Card Color Style" id="bg_and_text_color" summary="Colors of music/notification container backgrounds" default="5">
      <Item value="0" text="Follow system theme"/>
      <Item value="1" text="Sunset / Sunrise dynamic colors"/>
      <Item value="2" text="Dark background, white text"/>
      <Item value="3" text="White background, dark text"/>
      <Item value="4" text="All black theme"/>
      <Item value="5" text="All white theme"/>
    </NumberChoice>
    <NumberInput text="Music card opacity" summary="Container opacity percentage (0-100, default is 20)" id="bg_alpha_diy" default="20"/>
    <CheckBox text="Gaussian blur container" id="blur_mode" summary="Enable iOS-style glassmorphism blur for cards" default="1"/>
    <CheckBox text="White card border accent" id="bg_border" summary="Adds a subtle white outline highlight to cards" default="1"/>
    <NumberInput text="Card border opacity" summary="Card border stroke opacity (0-100, default is 100)" id="bg_border_alpha_diy" default="100"/>
    <NumberChoice text="Maximize album art size" id="album_style" default="0" summary="">
      <Item value="0" text="Standard large square"/>
      <Item value="1" text="Full screen immersive cover"/>
    </NumberChoice>
    <NumberChoice text="Album art background blur intensity" summary="Use style 2 or 3 if full-screen background flickers on stock Xiaomi Music app" id="Micover" default="0">
      <Item value="0" text="1. High blur"/>
      <Item value="1" text="2. Low blur"/>
      <Item value="2" text="3. Background image dim only"/>
    </NumberChoice>
    <CheckBox text="Keep screen wake in full screen music mode" id="bigCover_always_son" summary="Keeps screen on continuously while full-screen visualizer is active" default="0"/>
    <CheckBox text="Show keep-awake helper text prompts" id="alwayson_tips" summary="" default="1"/>
    <CheckBox text="Show help tip if album cover fails to read" id="covertips_on" summary="" default="1"/>
  </Group>
  
  <Group text="9. Notification Settings">
    <CheckBox text="Enable notifications" summary="Display system notification cards on lockscreen" id="notic_vis" default="1"/>
    <StringInput text="Note: Card size, colors, opacity, and borders mirror the Music Player card settings." id="1" default="ok" summary=""/>
    <CheckBox text="Notification manual collapse button" summary="Show toggle button to expand/collapse notifications when grouped" id="notice_hand_fold_btn" default="1"/>
    <NumberChoice text="Group notifications automatically" summary="" id="notice_fold_num" default="1">
      <Item value="1" text="More than 1 notification"/>
      <Item value="2" text="More than 2 notifications"/>
      <Item value="3" text="More than 3 notifications"/>
      <Item value="4" text="More than 4 notifications"/>
      <Item value="5" text="More than 5 notifications"/>
      <Item value="6" text="More than 6 notifications"/>
      <Item value="7" text="More than 7 notifications"/>
      <Item value="8" text="More than 8 notifications"/>
    </NumberChoice>
    <NumberInput text="Notification Title Font Size" id="noticeTitle_size" default="44" summary="Default is 44, valid range: 40~60"/>
    <NumberInput text="Notification Body Font Size" id="noticeContent_size" default="40" summary="Default is 40, valid range: 40~60"/>
    <NumberInput text="Notification Time Font Size" id="noticeTime_size" default="40" summary="Default is 40, valid range: 30~60"/>
  </Group>
  
  <Group text="10. Custom App &amp; Info Widget Card">
    <CheckBox text="Enable Custom Widget Container" summary=" " id="Card_function" default="0"/>
    <NumberChoice text="Widget container default tab" summary="" id="CardType_ID" default="0">
      <Item value="0" text="Favorites Shortcut Dock"/>
      <Item value="1" text="Custom Quote Card"/>
      <Item value="2" text="Mock Message Notification"/>
    </NumberChoice>
    <NumberChoice text="Widget theme colors" summary="" id="Card_ColorID" default="1">
      <Item value="0" text="Separate color theme"/>
      <Item value="1" text="Match Music / Notification card style"/>
    </NumberChoice>
    <NumberChoice text="Quote source type" summary="" id="SignType" default="0">
      <Item value="0" text="Pre-loaded system quotes"/>
      <Item value="1" text="User custom input quote"/>
    </NumberChoice>
    <StringInput text="-------------------------" id="1" default="" summary=""/>
    <NumberChoice text="Auto-cycle pre-loaded quotes" summary=" " id="sign_auto" default="0">
      <Item value="0" text="Cycle every time screen wakes"/>
      <Item value="1" text="Cycle every minute"/>
      <Item value="2" text="Cycle every hour"/>
      <Item value="3" text="Cycle every day"/>
    </NumberChoice>
    <StringInput text="Custom Quote content text" summary="" id="sign_diy" default="Stay true to yourself, make today worth remembering. ✨"/>
    <StringInput text="Custom Quote signature author" summary="" id="sign_name" default="DevInfinix"/>
    <StringInput text="------------------------------------" id="1" default="" summary=""/>
    <AppPicker text="Mock Message: App Icon selection" id="app_6"/>
    <StringInput text="Mock Message: Timestamp" summary="" id="FakeNoti_Time" default="2m ago"/>
    <StringInput text="Mock Message: Sender Name" summary="" id="FakeNoti_Title" default="DevInfinix"/>
    <StringInput text="Mock Message: Text content" summary="" id="FakeNoti_Content" default="Take a moment for yourself every day. You're doing great!"/>
    <StringInput text="------------------------------------" id="1" default="" summary=""/>
    <AppPicker text="App Shortcut 1" id="app_0"/>
    <AppPicker text="App Shortcut 2" id="app_1"/>
    <AppPicker text="App Shortcut 3" id="app_2"/>
    <AppPicker text="App Shortcut 4" id="app_3"/>
    <AppPicker text="App Shortcut 5" id="app_4"/>
    <AppPicker text="App Shortcut 6" id="app_5"/>
  </Group>
  
  <Group text="11. Lockscreen Control Center">
    <CheckBox text="Swipe down for Control Center" summary="" id="CC_slide_enable" default="0"/>
    <NumberChoice text="Control Center swipe trigger zone" summary="" id="CC_slide_id" default="0">
      <Item value="0" text="Top-right edge or full width"/>
      <Item value="1" text="Top-right corner only"/>
    </NumberChoice>
  </Group>
  
  <Group text="12. Standby / Charging Display">
    <NumberChoice text="Enable landscape Standby mode" summary=" " id="Standby_begin_y" default="0">
      <Item value="0" text="Off"/>
      <Item value="1" text="Swipe anywhere"/>
      <Item value="2" text="Swipe from top edge"/>
    </NumberChoice>
    <CheckBox text="Auto-start Standby when charger connected" summary="" id="StandbyChage" default="0"/>
    <NumberChoice text="Standby background wallpaper style" summary="" id="standby_bg" default="0">
      <Item value="0" text="Amoled Black"/>
      <Item value="1" text="Deep blur lockscreen wallpaper"/>
    </NumberChoice>
    <NumberChoice text="Night Standby Red Shift mode" summary=" " id="standby_darkmode" default="0">
      <Item value="0" text="Off"/>
      <Item value="1" text="When system Dark Mode active"/>
      <Item value="2" text="After sunset"/>
    </NumberChoice>
    <CheckBox text="Keep screen awake in Standby mode" summary=" " id="standby_always_on" default="0"/>
    <CheckBox text="Show Charging Battery ring indicator" summary="Display circular battery level meter" id="standby_battery" default="1"/>
    <CheckBox text="Show incoming notification count" summary="Show notification counts in Standby mode" id="standby_news" default="1"/>
    <CheckBox text="Show Standby setup assistant guide" summary="" id="placebo" default="1"/>
  </Group>
  
  <Group text="13. Always-On Display (AOD) Settings">
    <CheckBox text="Enable custom lockscreen AOD" summary=" " id="aod_on" default="0"/>
    <NumberChoice text="AOD wallpaper style" summary="" id="aod_wallpaper" default="0">
      <Item value="0" text="Black background"/>
      <Item value="1" text="Dimmed wallpaper theme"/>
    </NumberChoice>
    <NumberChoice text="AOD wallpaper wake animations" summary=" " id="Aod_Effects" default="1">
      <Item value="1" text="Effect 1"/>
      <Item value="2" text="Effect 2"/>
      <Item value="3" text="Effect 3"/>
      <Item value="4" text="Effect 4"/>
    </NumberChoice>
    <NumberChoice text="AOD screen timeout delay" summary=" " id="WakeTime_aod" default="0">
      <Item value="0" text="Turn off screen after 10 seconds"/>
      <Item value="1" text="Keep AOD active continuously"/>
    </NumberChoice>
    <NumberChoice text="AOD clock font color override" summary="Time color selection on Always-On display" id="aod_col_num" default="0">
      <Item value="0" text="Change clock text to solid white"/>
      <Item value="1" text="Retain current lockscreen clock color"/>
    </NumberChoice>
    <CheckBox text="Show incoming notification count" summary="Show notification count on AOD" id="aod_notic" default="1"/>
    <CheckBox text="Hide lockscreen widgets on AOD" summary="Turn off standard widgets in Always-On view" id="aod_widget" default="0"/>
    <CheckBox text="Prevent accidental screen wake clicks" summary="Locks touch gestures while in AOD mode to avoid accidental pocket dials" id="unlock_aod_vis" default="0"/>
  </Group>
  
  <Group text="14. Lockscreen Focus Mode">
    <CheckBox text="Enable Focus Mode display badge" summary=" " id="focus_mode" default="0"/>
    <StringInput text="Custom status icon subtitle text" summary="Text next to heart icon when focus mode active" id="heart_text" default="DevInfinix"/>
    <NumberInput text="Focus badge Y-axis height" id="focus_yy" default="205" summary=" "/>
  </Group>
  
  <Group text="15. Navigation Grabber Settings">
    <CheckBox text="Top-Right Status Bar grabber indicator" summary="" id="bar_top" default="1"/>
    <NumberChoice text="Top Bar Grabber color" summary="" id="topbar_color_num" default="0">
      <Item value="0" text="White"/>
      <Item value="1" text="Black"/>
      <Item value="2" text="Match clock text theme"/>
    </NumberChoice>
    <NumberInput text="Top Grabber X-position" id="bar_top_x" default="110" summary="Default is 110, valid range: 0~200"/>
    <NumberInput text="Top Grabber Y-position" id="bar_top_y" default="110" summary="Default is 110, valid range: 0~200"/>
    <StringInput text="-------------------------" id="5" default="" summary=""/>
    <CheckBox text="Bottom navigation unlock grabber bar" summary="" id="bar_bottom" default="1"/>
    <NumberChoice text="Bottom grabber double-tap shortcut action" summary="" id="bar_double" default="0">
      <Item value="0" text="Single double-tap opens edit layout interface"/>
      <Item value="1" text="Two double-taps opens edit layout interface"/>
      <Item value="2" text="Single double-tap launches Settings app"/>
      <Item value="3" text="Two double-taps launches Settings app"/>
    </NumberChoice>
    <StringInput text="Bottom unlock helper text prompt" summary="Note: This prompt will be hidden while Focus Mode is active." id="bar_text" default="Swipe up to unlock"/>
    <NumberChoice text="Bottom Grabber color" summary="Select black grabber when using light wallpapers" id="bar_color" default="0">
      <Item value="0" text="White"/>
      <Item value="1" text="Black"/>
    </NumberChoice>
    <CheckBox text="Require double-tap to unlock after Face Unlock" summary="" id="Enable_edit_btn" default="0"/>
  </Group>
  
  <Group text="16. Lockscreen Quick Launch Shortcuts">
    <CheckBox text="Flashlight &amp; Camera quick icons" summary="" id="shotcut" default="0"/>
    <NumberChoice text="Quick launch shortcut sizes" summary="" id="Shotcut_size" default="0">
      <Item value="0" text="Large buttons"/>
      <Item value="1" text="Small buttons"/>
    </NumberChoice>
    <NumberChoice text="Quick launch button style colors" summary="" id="shortcut_color_num" default="0">
      <Item value="0" text="White pill, white icon"/>
      <Item value="1" text="White pill, dark icon"/>
      <Item value="2" text="Dark pill, dark icon"/>
      <Item value="3" text="Dark pill, white icon"/>
    </NumberChoice>
    <NumberChoice text="Quick launch button interaction style" summary="" id="shortcut_action" default="0">
      <Item value="0" text="Single-tap (Instant)"/>
      <Item value="1" text="Double-tap (Accidental press filter)"/>
      <Item value="2" text="Long press (Pocket dial filter)"/>
    </NumberChoice>
    <CheckBox text="Enable shortcut outline borders" summary="" id="shotcut_border" default="1"/>
    <CheckBox text="Swap left/right shortcuts position" summary="" id="exchange_icon" default="0"/>
    <CheckBox text="Show missed call alert count" summary="Display badge for missed phone calls" id="call_on" default="1"/>
  </Group>
  
  <Group text="17. In-Display Fingerprint Sensor">
    <NumberChoice text="Fingerprint icon mode" summary="[Hide icon] Hides scan icon but scanner remains functional; [Disable AOD Scan] Hides icon and locks fingerprint scanner on Lockscreen" id="HideFod_unlock" default="0">
      <Item value="0" text="Show icon"/>
      <Item value="1" text="Hide icon"/>
      <Item value="2" text="Disable scan"/>
    </NumberChoice>
    <CheckBox text="Sensor overlay target indicator" summary="Draws a target over the sensor area (Applicable to first 4 sensor styles)" id="HideFod_show" default="0"/>
    <StringInput text="-----------" id="7" default="" summary=""/>
    <NumberChoice text="Fingerprint scanner visual style" summary=" " id="FancyFod_ID" default="0">
      <Item value="0" text="None (Standard layout)"/>
      <Item value="1" text="Style 1"/>
      <Item value="2" text="Style 2"/>
      <Item value="3" text="Style 3"/>
      <Item value="4" text="Style 4"/>
      <Item value="5" text="Style 5"/>
      <Item value="6" text="Style 6"/>
      <Item value="7" text="Style 7"/>
      <Item value="8" text="Style 8"/>
      <Item value="9" text="Style 9"/>
    </NumberChoice>
    <NumberInput text="Fingerprint icon opacity" summary="Icon transparency (0-100%, dynamic styles excluded)" id="fod_alpha" default="80"/>
    <CheckBox text="Blur background behind sensor" summary="" id="fod_bg_blur" default="0"/>
    <StringInput text="--------------------" id="8" default="" summary=""/>
    <CheckBox text="Hide fingerprint icon during music playback" summary="Recommended if music controller overlaps the fingerprint sensor" id="HideFod_musicstate_on" default="0"/>
    <CheckBox text="Hide fingerprint icon on successful Face Unlock" summary="" id="disableFod_face_state2" default="0"/>
