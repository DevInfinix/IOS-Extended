      <Item value="1" text="iOS-style lock padlock icon"/>
      <Item value="2" text="Smiling yellow emoji"/>
      <Item value="6" text="Cool glasses yellow emoji"/>
      <Item value="7" text="Playful tongue yellow emoji"/>
      <Item value="8" text="Grinning yellow emoji"/>
      <Item value="3" text="Love heart icon"/>
      <Item value="4" text="Emoji hand gestures"/>
      <Item value="5" text="Cat face emoji"/>
      <Item value="99" text="Off"/>
    </NumberChoice>
    <CheckBox text="Hide Face Unlock graphic entirely" summary="" id="face_detect_state_msg2_hide_icon" default="0"/>
    <NumberInput text="Lock indicator Y-axis position" id="Lock_y" default="140" summary="Lock Y-axis offset (Range: 0-200, default is 140. Ignored for default System style)"/>
